# Database
# On Railway, set this to the reference variable: ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgresql://...
# TLS override. Leave unset for sensible defaults (no SSL on localhost and on
# Railway's *.railway.internal private network; verified/unverified TLS elsewhere).
#   DATABASE_SSL=disable  -> never use SSL
#   DATABASE_SSL=require  -> force SSL even on the Railway private network
DATABASE_SSL=
# Optional but recommended for public/external Postgres: PEM contents of your
# provider's CA bundle. When set, the DB connection verifies the server
# certificate (rejects MITM). When unset, it falls back to unverified TLS + warning.
DATABASE_CA_CERT=

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI
OPENAI_API_KEY=sk-...

# Resend (email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=digest@churnlens.com

# Encryption (32-byte hex string for AES-256-GCM encryption of API keys)
ENCRYPTION_KEY=your-64-char-hex-string-here

# Internal cron secret
CRON_SECRET=your-random-secret

# App — public base URL (used for survey/login links and per-org Stripe webhooks).
# On Railway, set this to: https://${{ RAILWAY_PUBLIC_DOMAIN }}
NEXT_PUBLIC_APP_URL=https://app.churnlens.com
